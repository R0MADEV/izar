{
  "name": "izar",
  "version": "0.1.0",
  "description": "Personal AI assistant — local, cross-platform",
  "type": "module",
  "bin": {
    "izar": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --packages external --banner '#!/usr/bin/env node'",
    "start": "node dist/cli.js",
    "test": "bun test",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "files": ["dist"],
  "dependencies": {
    "ollama-ai-provider": "^1.2.0",
    "@clack/prompts": "^0.9.0",
    "ai": "^4.3.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "duck-duck-scrape": "^2.2.5",
    "vectra": "^0.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["ai", "assistant", "cli", "ollama", "local"],
  "license": "MIT"
}
